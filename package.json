{
  "name": "@hnkatze/fetchmate",
  "version": "1.0.0",
  "description": "Typed HTTP client with interceptors, retry, cache, and Angular support",
  "keywords": [
    "fetch",
    "http",
    "client",
    "typed",
    "typescript",
    "interceptors",
    "retry",
    "cache",
    "angular",
    "signals"
  ],
  "author": "hnkatze",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hnkatze/fetchmate.git"
  },
  "homepage": "https://github.com/hnkatze/fetchmate#readme",
  "bugs": {
    "url": "https://github.com/hnkatze/fetchmate/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./angular": {
      "import": {
        "types": "./dist/angular.d.mts",
        "default": "./dist/angular.mjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "msw": "^2.4.0",
    "@angular/core": "^17.0.0",
    "@angular/common": "^17.0.0",
    "rxjs": "^7.8.0"
  },
  "peerDependencies": {
    "@angular/core": ">=17.0.0",
    "@angular/common": ">=17.0.0",
    "rxjs": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/core": {
      "optional": true
    },
    "@angular/common": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
